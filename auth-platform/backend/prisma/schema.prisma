generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String?
  totpSecret        String?
  totpEnabled       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  devices           Device[]
  sessions          Session[]
  passkeys          Passkey[]
  riskEvents        RiskEvent[]
  approvalRequests  ApprovalRequest[]  @relation("Requester")
  approvalVotes     ApprovalVote[]
  approverRoles     ApproverRole[]
}

model Device {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint     String
  userAgent       String
  ipAddress       String?
  lastSeen        DateTime @default(now())
  trustScore      Int      @default(0)
  isTrusted       Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([userId, fingerprint])
}

model Passkey {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId        String   @unique
  credentialPublicKey Bytes
  counter             BigInt   @default(0)
  deviceType          String   @default("singleDevice")
  backedUp            Boolean  @default(false)
  transports          String?
  createdAt           DateTime @default(now())
  lastUsed            DateTime?
}

model Session {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token         String   @unique
  refreshToken  String   @unique
  deviceId      String?
  ipAddress     String?
  userAgent     String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  isRevoked     Boolean  @default(false)
}

model RiskEvent {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType   String
  riskScore   Int
  riskFactors String
  ipAddress   String?
  userAgent   String?
  decision    String
  explanation String?
  createdAt   DateTime @default(now())
}

model ApprovalPolicy {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  actionType      String
  requiredWeight  Int      @default(1)
  timeoutMinutes  Int      @default(60)
  escalationChain String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  approvalRequests ApprovalRequest[]
  approverRoles    ApproverRole[]
}

model ApproverRole {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  policyId  String
  policy    ApprovalPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  weight    Int            @default(1)
  priority  Int            @default(0)
  createdAt DateTime       @default(now())

  @@unique([userId, policyId])
}

model ApprovalRequest {
  id              String         @id @default(uuid())
  requesterId     String
  requester       User           @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  policyId        String
  policy          ApprovalPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  actionType      String
  actionPayload   String
  payloadHash     String
  status          String         @default("pending")
  currentWeight   Int            @default(0)
  requiredWeight  Int
  expiresAt       DateTime
  completedAt     DateTime?
  createdAt       DateTime       @default(now())

  votes           ApprovalVote[]
  auditLog        ApprovalAuditLog[]
}

model ApprovalVote {
  id          String          @id @default(uuid())
  requestId   String
  request     ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approverId  String
  approver    User            @relation(fields: [approverId], references: [id], onDelete: Cascade)
  decision    String
  weight      Int
  signature   String
  signedData  String
  createdAt   DateTime        @default(now())

  @@unique([requestId, approverId])
}

model ApprovalAuditLog {
  id          String          @id @default(uuid())
  requestId   String
  request     ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  action      String
  actorId     String?
  details     String
  prevHash    String?
  entryHash   String
  createdAt   DateTime        @default(now())
}

model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model FailoverStatus {
  id          String   @id @default(uuid())
  provider    String   @unique
  isHealthy   Boolean  @default(true)
  lastCheck   DateTime @default(now())
  failCount   Int      @default(0)
}
